{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "commonjs",
    "target": "ES6",
    "moduleResolution": "node",

    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "types": ["node"],

    "sourceMap": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}